{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "order_id": { "type": "string" },
    "customer_id": { "type": "integer" },
    "checkout_type": { "type": "string" },
    "device_type": { "type": "string" },
    "payment_gateway": { "type": "string" },
    "acquisition_channel": { "type": "string" },
    "shipping_address": {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "pin_code": { "type": "string" }
      },
      "required": ["city", "state", "country", "pin_code"]
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "line_item_id": { "type": "string" },
          "item_sku": { "type": "string" },
          "category": { "type": "string" },
          "brand": { "type": "string" },
          "supplier": { "type": "string" },
          "unit_price": { "type": "number" },
          "quantity": { "type": "integer" },
          "fulfillment_center": { "type": "string" },
          "shipping_carrier": { "type": "string" },
          "item_status": { "type": "string" },
          "promo_code_applied": { "type": ["string", "null"] },
          "return_reason": { "type": ["string", "null"] }
        },
        "required": ["line_item_id", "item_sku", "unit_price", "quantity"]
      },
      "minItems": 1
    },
    "order_timestamp": { "type": "string", "format": "date-time" }
  },
  "required": [
    "event_id", 
    "order_id", 
    "customer_id", 
    "checkout_type",
    "device_type",
    "payment_gateway",
    "acquisition_channel",
    "shipping_address", 
    "line_items", 
    "order_timestamp"
  ]
}